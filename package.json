{
  "name": "tally",
  "version": "0.1.0",
  "description": "Personal finance CLI — budget tracking & reporting",
  "keywords": [
    "budget",
    "cli",
    "finance",
    "personal-finance",
    "sqlite",
    "terminal"
  ],
  "license": "MIT",
  "author": "Justin Rabiller",
  "repository": {
    "type": "git",
    "url": "https://github.com/snutij/tally.git"
  },
  "bin": {
    "tally": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "db:reset": "rm -f ~/.local/share/tally/tally.db",
    "db:seed": "tally import csv tests/fixtures/demo.csv",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0",
    "commander": "14.0.3",
    "csv-parse": "6.2.1",
    "node-llama-cpp": "3.18.1",
    "ora": "9.3.0",
    "temporal-polyfill": "0.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tsdown": "0.21.4",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  },
  "overrides": {
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
